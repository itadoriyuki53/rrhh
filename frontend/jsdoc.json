{
    "tags": {
        "allowUnknownTags": true,
        "dictionaries": [
            "jsdoc",
            "closure"
        ]
    },
    "source": {
        "include": [
            "src"
        ],
        "includePattern": "\\.(jsx|js)$",
        "excludePattern": "(node_modules/|bower_components)"
    },
    "plugins": [
        "plugins/markdown"
    ],
    "opts": {
        "template": "templates/default",
        "encoding": "utf8",
        "destination": "../docs/frontend",
        "recurse": true,
        "verbose": true
    },
    "templates": {
        "default": {
            "outputSourceFiles": true,
            "includeDate": true
        }
    }
}